# Stripe — get these from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Webhook Secret — from `stripe listen --forward-to localhost:3002/webhooks/stripe`
STRIPE_WEBHOOK_SECRET=whsec_...

# Production host used for mailer links (password reset, confirmation emails)
APP_HOST=example.com

# From address for Devise emails
DEVISE_MAILER_SENDER=no-reply@example.com
